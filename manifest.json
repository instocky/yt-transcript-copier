{
  "manifest_version": 3,
  "name": "YT Transcript Copier",
  "version": "1.4.1",
  "description": "Copy or export full YouTube transcripts, including localhost batch orchestration",
  "permissions": [
    "contextMenus",
    "clipboardWrite",
    "scripting",
    "downloads",
    "alarms",
    "storage",
    "tabs"
  ],
  "host_permissions": ["https://www.youtube.com/*", "http://127.0.0.1:8765/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
