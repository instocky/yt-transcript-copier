{
  "manifest_version": 3,
  "name": "YT Transcript Copier",
  "version": "1.2.0",
  "description": "Copy full YouTube transcript via context menu",
  "permissions": ["contextMenus", "clipboardWrite", "scripting"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
